/**
 * pdf-column-catalog.ts
 *
 * THE SINGLE SOURCE OF TRUTH for all PDF column definitions.
 *
 * Every column that can ever appear in an invoice PDF — main page or appendix —
 * is defined exactly once in this file as an entry in PDF_COLUMN_CATALOG.
 *
 * ─── How other parts of the system use this catalog ─────────────────────────
 *
 * PDF renderer         — iterates active columns, calls renderCell(item, colDef)
 *                        for each; never hardcodes a column key or format
 * Width calculator     — reads defaultWidthPt / minWidthPt to auto-scale columns
 *                        to the usable page width (portrait or landscape)
 * Vorlage editor UI    — builds the column picker from this array (uiLabel +
 *                        description shown as tooltip)
 * Zod validator        — derives the valid PdfColumnKey union from catalog keys
 * TypeScript types     — PdfColumnKey is auto-derived; never manually maintained
 *
 * ─── Adding a new column ────────────────────────────────────────────────────
 *
 * 1. Add one PdfColumnDef entry to PDF_COLUMN_CATALOG below
 * 2. Done. No other file needs to change.
 *
 * ─── Constraints ────────────────────────────────────────────────────────────
 *
 * - Never define column keys, labels, widths, or formats anywhere else
 * - dataField uses dot-notation for nested access: "trip_meta_snapshot.driver_name"
 * - defaultWidthPt values assume portrait A4 usable width = 515pt
 *   (landscape A4 usable = 770pt — the width calculator scales proportionally)
 */
// ─── Column definition shape ──────────────────────────────────────────────────
export interface PdfColumnDef {
  /** Machine key — stored in DB jsonb arrays, never rename after first release */
  key: string;
  /** German column header rendered in the PDF table */
  label: string;
  /** German label shown in the Vorlage editor column picker */
  uiLabel: string;
  /** One-line German description shown as tooltip in the column picker */
  description: string;
  /**
   * Dot-notation path into InvoiceLineItemRow (or trip_meta_snapshot sub-object).
   * Examples: "line_date", "client_name", "trip_meta_snapshot.driver_name"
   */
  dataField: string;
  /** Default column width in PDF points for portrait A4 (usable = 515pt) */
  defaultWidthPt: number;
  /** Minimum column width — never shrink below this regardless of column count */
  minWidthPt: number;
  /** Text alignment in the PDF cell */
  align: 'left' | 'right' | 'center';
  /**
   * How the raw value is formatted in the PDF cell.
   * The renderer has a single switch on this field — no per-key formatting logic.
   * - 'date'     → "05.04.2026" (de-DE locale)
   * - 'currency' → "€ 42,50"
   * - 'percent'  → "7%"
   * - 'km'       → "12,4 km"
   * - 'integer'  → "3" (quantity, position)
   * - 'text'     → raw string, fallback "—"
   */
  format: 'date' | 'currency' | 'percent' | 'km' | 'integer' | 'text';
  /**
   * When true, this column is hidden in the main page column picker.
   * It still appears in the appendix picker.
   * Use for columns with too much text for the main invoice table.
   */
  appendixOnly?: boolean;
}
