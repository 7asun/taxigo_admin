-- ─── PDF-Vorlagen ────────────────────────────────────────────────────────────
-- Named, reusable column profile templates per company.
-- Each Vorlage defines which columns appear in the main invoice page
-- and the appendix page. The appendix automatically switches to landscape
-- orientation when appendix_columns contains more than 7 entries.
create table pdf_vorlagen (
  id               uuid        primary key default gen_random_uuid(),
  company_id       uuid        not null references company_profiles(company_id) on delete cascade,
  name             text        not null,
  description      text,
  -- Ordered arrays of PdfColumnKey strings — validated by app-layer Zod schema
  main_columns     jsonb       not null default '["trip_date","client_name","billing_variant","net_price","tax_rate","gross_price"]',
  appendix_columns jsonb       not null default '["trip_date","client_name","pickup_address","dropoff_address","distance_km","net_price"]',
  -- Only one default Vorlage per company (enforced by partial unique index below)
  is_default       boolean     not null default false,
  created_at       timestamptz not null default now(),
  updated_at       timestamptz not null default now()
);
-- Enforce at most one is_default = true per company
create unique index pdf_vorlagen_company_default_idx
  on pdf_vorlagen(company_id)
  where is_default = true;
-- ─── Kostenträger assignment ──────────────────────────────────────────────────
-- Each Kostenträger (payer) can be assigned one Vorlage.
-- Null = fall through to company default Vorlage, then system fallback.
alter table payers
  add column pdf_vorlage_id uuid references pdf_vorlagen(id) on delete set null;
-- ─── Per-invoice column override ─────────────────────────────────────────────
-- Dispatchers can override columns for a single invoice in builder Step 5.
-- Null = resolve from Kostenträger Vorlage → company default → system fallback.
-- Shape: { main_columns: PdfColumnKey[], appendix_columns: PdfColumnKey[] }
alter table invoices
  add column pdf_column_override jsonb;
-- ─── RLS ─────────────────────────────────────────────────────────────────────
alter table pdf_vorlagen enable row level security;
create policy "company members can manage their pdf_vorlagen"
  on pdf_vorlagen for all
  using (
    company_id = (
      select company_id from accounts where id = auth.uid()
    )
  );
