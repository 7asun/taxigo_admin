/**
 * Union type of all valid column keys, auto-derived from the catalog.
 * Never maintain this manually — it is always in sync with the catalog.
 */
export type PdfColumnKey = typeof PDF_COLUMN_CATALOG[number]['key'];
/**
 * Quick lookup map: key → PdfColumnDef.
 * Use this in the renderer instead of .find() in a hot render loop.
 */
export const PDF_COLUMN_MAP: Record<string, PdfColumnDef> = Object.fromEntries(
  PDF_COLUMN_CATALOG.map((col) => [col.key, col])
);
/**
 * Zod schema for validating a stored columns array.
 * Rejects unknown keys at the API boundary before any DB write.
 */
export const VALID_COLUMN_KEYS = PDF_COLUMN_CATALOG.map((c) => c.key) as [string, ...string[]];
/** Columns available for the main invoice page picker (excludes appendixOnly) */
export const MAIN_PAGE_COLUMNS = PDF_COLUMN_CATALOG.filter((c) => !c.appendixOnly);
/** Columns available for the appendix picker (all columns) */
export const APPENDIX_COLUMNS = PDF_COLUMN_CATALOG;
/**
 * System fallback column sets — used when no Vorlage is assigned at any level.
 * These mirror the columns that were previously hardcoded in the PDF renderer.
 */
